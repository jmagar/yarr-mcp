# =============================================================================
# .env.example — Secrets and URLs for the Yarr MCP server
#
# SPLIT PHILOSOPHY — Rule of thumb:
#   Secrets and URLs go here (.env), everything else in config.toml.
#   Never put secrets in config.toml (it's checked into git).
#   Never put non-secret config here (it becomes hard to track).
#
# Concretely:
#   .env         → API URLs, API keys, tokens, OAuth credentials, passwords
#   config.toml  → Ports, bind addresses, feature flags, tuning knobs,
#                  timeouts, log levels, retention settings
#
# Usage:
#   cp .env.example .env
#   # Edit .env — fill in real values
#   # .env is in .gitignore; never commit it
# =============================================================================

# ── Media automation services ────────────────────────────────────────────────
# List the service instances yarr should expose. Each name expands to
# YARR_<NAME>_* variables, with non-alphanumeric chars converted to "_".

YARR_SERVICES=sonarr,radarr,prowlarr,plex

YARR_SONARR_URL=http://sonarr:8989
YARR_SONARR_API_KEY=change-me

YARR_RADARR_URL=http://radarr:7878
YARR_RADARR_API_KEY=change-me

YARR_PROWLARR_URL=http://prowlarr:9696
YARR_PROWLARR_API_KEY=change-me

YARR_PLEX_URL=http://plex:32400
YARR_PLEX_TOKEN=change-me

# qBittorrent uses cookie login rather than API-key auth.
# YARR_QBITTORRENT_URL=http://qbittorrent:8080
# YARR_QBITTORRENT_USERNAME=admin
# YARR_QBITTORRENT_PASSWORD=change-me

# Jellyfin uses token auth.
# YARR_JELLYFIN_URL=http://jellyfin:8096
# YARR_JELLYFIN_TOKEN=change-me

# ── MCP HTTP server ───────────────────────────────────────────────────────────
# YARR_MCP_TOKEN — static bearer token that MCP clients must present.
#   Every request to /mcp must include: Authorization: Bearer <this-value>
#   Generate with: openssl rand -hex 32   or   just gen-token
#   Omit (or set YARR_MCP_NO_AUTH=true) for loopback-only dev mode only.

# YARR_MCP_TOKEN=    # generate with: openssl rand -hex 32   or   just gen-token

# Bind host (default: 127.0.0.1 — loopback only). Set to 0.0.0.0 for external access.
# YARR_MCP_HOST=127.0.0.1

# Bind port (default: 40070).
# YARR_MCP_PORT=40070

# Bound Code Mode concurrency, admission wait, and execution time.
# YARR_MCP_CODEMODE_MAX_CONCURRENT=4
# YARR_MCP_CODEMODE_QUEUE_TIMEOUT_MS=500
# YARR_MCP_CODEMODE_TIMEOUT_SECS=30

# Disable auth entirely. ONLY safe when the server is bound to 127.x.
# Set to true only for local development when you control the machine.
# YARR_MCP_NO_AUTH=false

# Trusted-gateway no-auth mode. Set to true when behind a reverse proxy that
# enforces its own auth (e.g. Authelia, Traefik Forward Auth). Non-loopback only.
# YARR_NOAUTH=false

# Auth mode: "bearer" (default) or "oauth".
# YARR_MCP_AUTH_MODE=bearer

# Extra Host header values accepted by the server (comma-separated).
# YARR_MCP_ALLOWED_HOSTS=

# Extra CORS origins accepted by the server (comma-separated).
# YARR_MCP_ALLOWED_ORIGINS=

# ── OAuth (Google) ────────────────────────────────────────────────────────────
# Only needed when YARR_MCP_AUTH_MODE=oauth in config.toml.
# Leave commented out for bearer-token-only mode (the simpler default).
#
# Steps to enable OAuth:
#   1. Create a Web application OAuth client at console.cloud.google.com
#   2. Add the redirect URIs documented in docs/AUTH.md
#   3. Set YARR_MCP_AUTH_MODE=oauth in config.toml
#   4. Fill in the values below

# Public URL of your MCP server (used as OAuth issuer / resource metadata URL).
# Must be reachable from clients. Required in OAuth mode.
# YARR_MCP_PUBLIC_URL=https://yarr.tootie.tv

# Google OAuth 2.0 credentials
# YARR_MCP_GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com
# YARR_MCP_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Bootstrap admin email — first allowed Google account for OAuth
# YARR_MCP_AUTH_ADMIN_EMAIL=admin@example.com

# Local OAuth SQLite database. Exactly one process can own the adjacent
# `.instance.lock`; NFS/shared SQLite does not support multiple replicas.
# YARR_MCP_AUTH_SQLITE_PATH=/data/auth.db

# ── Docker runtime ────────────────────────────────────────────────────────────
# These are read by docker-compose.yml, not by the binary. The image always
# drops to UID/GID 1000 after the entrypoint prepares /data.
# DOCKER_NETWORK=mcp
# Required by docker-compose.prod.yml. Use the digest produced by the clean
# Docker Publish workflow; never use `latest` for production deployments.
# YARR_MCP_IMAGE=ghcr.io/dinglebear-ai/yarr@sha256:<64-hex-digest>

# ── Logging ───────────────────────────────────────────────────────────────────
# Use debug for development, warn for high-throughput servers.
# RUST_LOG=info
# RUST_LOG=info,rmcp=warn,yarr=debug

# Disable ANSI color in console output.
# NO_COLOR=1

# Force ANSI color even when stderr is not a TTY.
# FORCE_COLOR=1
