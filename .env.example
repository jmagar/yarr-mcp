# =============================================================================
# .env.example — Secrets and URLs for the Rustarr MCP server
#
# SPLIT PHILOSOPHY — Rule of thumb:
#   Secrets and URLs go here (.env), everything else in config.toml.
#   Never put secrets in config.toml (it's checked into git).
#   Never put non-secret config here (it becomes hard to track).
#
# Concretely:
#   .env         → API URLs, API keys, tokens, OAuth credentials, passwords
#   config.toml  → Ports, bind addresses, feature flags, tuning knobs,
#                  timeouts, log levels, retention settings
#
# Usage:
#   cp .env.example .env
#   # Edit .env — fill in real values
#   # .env is in .gitignore; never commit it
# =============================================================================

# ── Media automation services ────────────────────────────────────────────────
# List the service instances rustarr should expose. Each name expands to
# RUSTARR_<NAME>_* variables, with non-alphanumeric chars converted to "_".

RUSTARR_SERVICES=sonarr,radarr,prowlarr,plex

RUSTARR_SONARR_URL=http://sonarr:8989
RUSTARR_SONARR_API_KEY=change-me

RUSTARR_RADARR_URL=http://radarr:7878
RUSTARR_RADARR_API_KEY=change-me

RUSTARR_PROWLARR_URL=http://prowlarr:9696
RUSTARR_PROWLARR_API_KEY=change-me

RUSTARR_PLEX_URL=http://plex:32400
RUSTARR_PLEX_TOKEN=change-me

# qBittorrent uses cookie login rather than API-key auth.
# RUSTARR_QBITTORRENT_URL=http://qbittorrent:8080
# RUSTARR_QBITTORRENT_USERNAME=admin
# RUSTARR_QBITTORRENT_PASSWORD=change-me

# Jellyfin uses token auth.
# RUSTARR_JELLYFIN_URL=http://jellyfin:8096
# RUSTARR_JELLYFIN_TOKEN=change-me

# ── MCP HTTP server ───────────────────────────────────────────────────────────
# RUSTARR_MCP_TOKEN — static bearer token that MCP clients must present.
#   Every request to /mcp must include: Authorization: Bearer <this-value>
#   Generate with: openssl rand -hex 32   or   just gen-token
#   Omit (or set RUSTARR_MCP_NO_AUTH=true) for loopback-only dev mode only.

# RUSTARR_MCP_TOKEN=    # generate with: openssl rand -hex 32   or   just gen-token

# Bind host (default: 127.0.0.1 — loopback only). Set to 0.0.0.0 for external access.
# RUSTARR_MCP_HOST=127.0.0.1

# Bind port (default: 40070).
# RUSTARR_MCP_PORT=40070

# Disable auth entirely. ONLY safe when the server is bound to 127.x.
# Set to true only for local development when you control the machine.
# RUSTARR_MCP_NO_AUTH=false

# Trusted-gateway no-auth mode. Set to true when behind a reverse proxy that
# enforces its own auth (e.g. Authelia, Traefik Forward Auth). Non-loopback only.
# RUSTARR_NOAUTH=false

# Auth mode: "bearer" (default) or "oauth".
# RUSTARR_MCP_AUTH_MODE=bearer

# Extra Host header values accepted by the server (comma-separated).
# RUSTARR_MCP_ALLOWED_HOSTS=

# Extra CORS origins accepted by the server (comma-separated).
# RUSTARR_MCP_ALLOWED_ORIGINS=

# ── OAuth (Google) ────────────────────────────────────────────────────────────
# Only needed when RUSTARR_MCP_AUTH_MODE=oauth in config.toml.
# Leave commented out for bearer-token-only mode (the simpler default).
#
# Steps to enable OAuth:
#   1. Create a Web application OAuth client at console.cloud.google.com
#   2. Add your redirect URIs (`rustarr setup plugin-hook` can report them)
#   3. Set RUSTARR_MCP_AUTH_MODE=oauth in config.toml
#   4. Fill in the values below

# Public URL of your MCP server (used as OAuth issuer / resource metadata URL).
# Must be reachable from clients. Required in OAuth mode.
# RUSTARR_MCP_PUBLIC_URL=https://rustarr.tootie.tv

# Google OAuth 2.0 credentials
# RUSTARR_MCP_GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com
# RUSTARR_MCP_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Bootstrap admin email — first allowed Google account for OAuth
# RUSTARR_MCP_AUTH_ADMIN_EMAIL=admin@example.com

# ── Docker runtime ────────────────────────────────────────────────────────────
# These are read by docker-compose.yml and entrypoint.sh, not by the binary.
# PUID=1000
# PGID=1000
# DOCKER_NETWORK=mcp
# VERSION=latest

# ── Logging ───────────────────────────────────────────────────────────────────
# Use debug for development, warn for high-throughput servers.
# RUST_LOG=info
# RUST_LOG=info,rmcp=warn,rustarr=debug

# Disable ANSI color in console output.
# NO_COLOR=1

# Force ANSI color even when stderr is not a TTY.
# FORCE_COLOR=1
