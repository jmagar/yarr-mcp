# =============================================================================
# .gitattributes — Git LFS tracking rules for rustarr
#
# The bin/ directory holds pre-built binaries for plugin installs. Users who
# install the plugin get the binary without needing a Rust toolchain.
#
# Pattern §21: Every server repo tracks bin/* via Git LFS.
#
# To update the binary:
#   cargo xtask dist          # builds and copies to bin/
#   git add bin/rustarr       # stage the LFS pointer
#   git commit -m "chore: update binary vX.Y.Z"
#   git push                  # LFS upload happens automatically
#
# If you add Windows binaries (.exe), they are already covered by bin/*.
# =============================================================================

# ── Compiled binaries ─────────────────────────────────────────────────────────
# bin/* covers release binaries. No need to list individual filenames.
bin/* filter=lfs diff=lfs merge=lfs -text
plugins/*/bin/* filter=lfs diff=lfs merge=lfs -text

# ── Release archives ──────────────────────────────────────────────────────────
# Release archives are tracked through Git LFS so they do not bloat git history.
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text

# ── Optional: other binary types ──────────────────────────────────────────────
# Uncomment if rustarr ships .wasm modules, .so shared libs, or other large
# binary formats as part of the plugin distribution.
# *.wasm filter=lfs diff=lfs merge=lfs -text
# *.so   filter=lfs diff=lfs merge=lfs -text
# *.dylib filter=lfs diff=lfs merge=lfs -text
