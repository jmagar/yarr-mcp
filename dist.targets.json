{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schemaVersion": 1,
  "identity": {
    "binaryName": "yarr",
    "canonicalRepo": "dinglebear-ai/yarr",
    "npmPackage": "yarr-mcp",
    "mcpName": "ai.dinglebear/yarr-mcp"
  },
  "versionContract": {
    "mode": "coupled-release-tag",
    "tagPrefix": "v",
    "files": [
      "Cargo.toml",
      "Cargo.lock",
      "xtask/Cargo.toml",
      ".release-please-manifest.json",
      "packages/yarr-mcp/package.json",
      "server.json"
    ]
  },
  "integrity": {
    "checksumAsset": "SHA256SUMS",
    "provenanceDigest": "github-release-api-sha256",
    "archiveMembers": "single-regular-binary"
  },
  "targets": [
    {
      "rustTarget": "x86_64-unknown-linux-gnu",
      "nodePlatform": "linux",
      "nodeArch": "x64",
      "releaseMatrixArch": "x86_64",
      "archiveBinary": "yarr",
      "asset": "yarr-x86_64.tar.gz",
      "exeExtension": ""
    },
    {
      "rustTarget": "x86_64-pc-windows-gnu",
      "nodePlatform": "win32",
      "nodeArch": "x64",
      "releaseMatrixArch": "windows-x86_64",
      "archiveBinary": "yarr.exe",
      "asset": "yarr-windows-x86_64.tar.gz",
      "exeExtension": ".exe"
    }
  ]
}
