{
  "name": "yarr-mcp",
  "version": "2.0.0",
  "description": "Node launcher for the yarr Rust MCP server and CLI for self-hosted media automation fleets.",
  "license": "MIT",
  "homepage": "https://github.com/jmagar/yarr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmagar/yarr.git",
    "directory": "packages/yarr-mcp"
  },
  "bugs": {
    "url": "https://github.com/jmagar/yarr/issues"
  },
  "bin": {
    "yarr-mcp": "bin/yarr.js",
    "yarr": "bin/yarr.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "dist.targets.json",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "scripts": {
    "prepack": "node scripts/sync-readme.js && node scripts/sync-targets.js",
    "postinstall": "node scripts/install.js",
    "test": "node --test",
    "check": "node --check bin/yarr.js && node --check scripts/install.js && node --check lib/download.js && node --check lib/platform.js && node --check scripts/sync-readme.js && node --check scripts/sync-targets.js && node --check scripts/check-package.js && node scripts/check-package.js",
    "prepublishOnly": "node scripts/check-package.js --release"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "rmcp",
    "rust",
    "cli",
    "homelab",
    "self-hosted",
    "media-server",
    "sonarr",
    "radarr",
    "prowlarr",
    "plex",
    "jellyfin",
    "tautulli",
    "sabnzbd",
    "qbittorrent",
    "overseerr",
    "bazarr",
    "automation"
  ],
  "mcpName": "ai.dinglebear/yarr-mcp",
  "author": {
    "name": "dinglebear.ai",
    "url": "https://dinglebear.ai"
  }
}
