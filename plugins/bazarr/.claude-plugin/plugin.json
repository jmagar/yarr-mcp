{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "bazarr",
  "description": "Check wanted/missing subtitles for movies and series, list providers, and trigger subtitle searches in Bazarr via its REST API. Skills-only, no MCP server required.",
  "author": {
    "name": "Jacob Magar",
    "email": "jmagar@users.noreply.github.com"
  },
  "repository": "https://github.com/jmagar/rustarr",
  "homepage": "https://github.com/jmagar/rustarr",
  "license": "MIT",
  "keywords": [
    "bazarr",
    "subtitles",
    "arr",
    "media",
    "homelab"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "userConfig": {
    "bazarr_url": {
      "type": "string",
      "title": "Bazarr URL",
      "description": "Bazarr base URL, e.g. http://localhost:6767 (no trailing slash).",
      "required": false
    },
    "bazarr_api_key": {
      "type": "string",
      "title": "Bazarr API key",
      "description": "Bazarr API key (Settings -> General -> Security).",
      "required": false,
      "sensitive": true
    }
  }
}
