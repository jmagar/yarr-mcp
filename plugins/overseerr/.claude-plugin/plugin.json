{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "overseerr",
  "description": "List, search, create, approve, and decline media requests in Overseerr via its REST API. Skills-only, no MCP server required.",
  "author": {
    "name": "Jacob Magar",
    "email": "jmagar@users.noreply.github.com"
  },
  "repository": "https://github.com/jmagar/rustarr",
  "homepage": "https://github.com/jmagar/rustarr",
  "license": "MIT",
  "keywords": [
    "overseerr",
    "requests",
    "media",
    "plex",
    "homelab"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "userConfig": {
    "overseerr_url": {
      "type": "string",
      "title": "Overseerr URL",
      "description": "Overseerr base URL, e.g. http://localhost:5055 (no trailing slash).",
      "required": false
    },
    "overseerr_api_key": {
      "type": "string",
      "title": "Overseerr API key",
      "description": "Overseerr API key (Settings -> General).",
      "required": false,
      "sensitive": true
    }
  }
}
