{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "plex",
  "description": "Check server status, active sessions (who's watching), libraries, and recently added items in Plex via its API. Skills-only, no MCP server required.",
  "author": {
    "name": "Jacob Magar",
    "email": "jmagar@users.noreply.github.com"
  },
  "repository": "https://github.com/jmagar/rustarr",
  "homepage": "https://github.com/jmagar/rustarr",
  "license": "MIT",
  "keywords": [
    "plex",
    "media-server",
    "streaming",
    "homelab"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "userConfig": {
    "plex_url": {
      "type": "string",
      "title": "Plex URL",
      "description": "Plex Media Server base URL incl. port, e.g. http://localhost:32400.",
      "required": false
    },
    "plex_token": {
      "type": "string",
      "title": "Plex token",
      "description": "Plex X-Plex-Token.",
      "required": false,
      "sensitive": true
    }
  }
}
