{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "prowlarr",
  "description": "List indexers, run searches across them, and check indexer health and stats in Prowlarr via its REST API. Skills-only, no MCP server required.",
  "author": {
    "name": "Jacob Magar",
    "email": "jmagar@users.noreply.github.com"
  },
  "repository": "https://github.com/dinglebear-ai/yarr",
  "homepage": "https://github.com/dinglebear-ai/yarr",
  "license": "MIT",
  "keywords": [
    "prowlarr",
    "indexers",
    "arr",
    "media",
    "homelab"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "userConfig": {
    "prowlarr_url": {
      "type": "string",
      "title": "Prowlarr URL",
      "description": "Prowlarr base URL, e.g. http://localhost:9696 (no trailing slash).",
      "required": false
    },
    "prowlarr_api_key": {
      "type": "string",
      "title": "Prowlarr API key",
      "description": "Prowlarr API key (Settings -> General).",
      "required": false,
      "sensitive": true
    }
  }
}
