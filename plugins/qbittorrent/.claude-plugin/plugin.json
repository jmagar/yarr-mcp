{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "qbittorrent",
  "description": "List, add, pause, resume, and remove torrents and check transfer stats in qBittorrent via its WebUI API. Skills-only, no MCP server required.",
  "author": {
    "name": "Jacob Magar",
    "email": "jmagar@users.noreply.github.com"
  },
  "repository": "https://github.com/jmagar/rustarr",
  "homepage": "https://github.com/jmagar/rustarr",
  "license": "MIT",
  "keywords": [
    "qbittorrent",
    "torrents",
    "downloads",
    "homelab"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "userConfig": {
    "qbittorrent_url": {
      "type": "string",
      "title": "qBittorrent URL",
      "description": "qBittorrent WebUI base URL, e.g. http://localhost:8080 (no trailing slash).",
      "required": false
    },
    "qbittorrent_username": {
      "type": "string",
      "title": "qBittorrent username",
      "description": "qBittorrent WebUI username.",
      "required": false
    },
    "qbittorrent_password": {
      "type": "string",
      "title": "qBittorrent password",
      "description": "qBittorrent WebUI password.",
      "required": false,
      "sensitive": true
    }
  }
}
