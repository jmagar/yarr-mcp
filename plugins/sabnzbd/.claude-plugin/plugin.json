{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "sabnzbd",
  "description": "View, pause, resume, and manage the SABnzbd Usenet download queue and history via its REST API. Skills-only, no MCP server required.",
  "author": {
    "name": "Jacob Magar",
    "email": "jmagar@users.noreply.github.com"
  },
  "repository": "https://github.com/dinglebear-ai/yarr",
  "homepage": "https://github.com/dinglebear-ai/yarr",
  "license": "MIT",
  "keywords": [
    "sabnzbd",
    "usenet",
    "downloads",
    "nzb",
    "homelab"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "userConfig": {
    "sabnzbd_url": {
      "type": "string",
      "title": "SABnzbd URL",
      "description": "SABnzbd base URL, e.g. http://localhost:8080 (no trailing slash).",
      "required": false
    },
    "sabnzbd_api_key": {
      "type": "string",
      "title": "SABnzbd API key",
      "description": "SABnzbd API key (Config -> General).",
      "required": false,
      "sensitive": true
    }
  }
}
