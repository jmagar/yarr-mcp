#!/usr/bin/env python3
"""Apply Rustarr's no-MCP plugin variant rules.

The `marketplace-no-mcp` branch keeps the plugin assets available while
removing bundled MCP server registrations for environments that register
Rustarr through a gateway or another explicit MCP config.
"""

from __future__ import annotations

import json
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
PLUGIN_ROOT = ROOT / "plugins" / "rustarr"
MCP_JSON = PLUGIN_ROOT / ".mcp.json"
GEMINI_EXTENSION = PLUGIN_ROOT / "gemini-extension.json"


def read_json(path: Path) -> Any:
    return json.loads(path.read_text())


def write_json(path: Path, data: Any) -> None:
    path.write_text(json.dumps(data, indent=2, ensure_ascii=True) + "\n")


def remove_mcp_config() -> bool:
    if not MCP_JSON.exists():
        return False
    MCP_JSON.unlink()
    return True


def strip_gemini_mcp_servers() -> bool:
    data = read_json(GEMINI_EXTENSION)
    if not isinstance(data, dict) or "mcpServers" not in data:
        return False
    data.pop("mcpServers")
    write_json(GEMINI_EXTENSION, data)
    return True


def main() -> int:
    removed_mcp = remove_mcp_config()
    stripped_gemini = strip_gemini_mcp_servers()

    if removed_mcp:
        print(f"removed MCP config: {MCP_JSON.relative_to(ROOT)}")
    if stripped_gemini:
        print(f"stripped Gemini MCP servers: {GEMINI_EXTENSION.relative_to(ROOT)}")
    if not removed_mcp and not stripped_gemini:
        print("no-MCP plugin rules already applied")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
