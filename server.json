{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.dinglebear/yarr-mcp",
  "title": "Yarr MCP",
  "description": "MCP server for querying and automating a configured media automation fleet.",
  "version": "2.0.1",
  "websiteUrl": "https://github.com/jmagar/yarr",
  "repository": {
    "url": "https://github.com/jmagar/yarr",
    "source": "github",
    "id": "1247261733"
  },
  "icons": [
    {
      "src": "https://avatars.githubusercontent.com/u/38927646?v=4",
      "mimeType": "image/png",
      "sizes": [
        "460x460"
      ],
      "theme": "dark"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "yarr-mcp",
      "version": "2.0.1",
      "runtimeHint": "npx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "Run Yarr MCP over stdio.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "isRepeated": false
        }
      ],
      "environmentVariables": [
        {
          "name": "YARR_SONARR_URL",
          "description": "Optional Sonarr base URL.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "http://sonarr:8989"
        },
        {
          "name": "YARR_SONARR_API_KEY",
          "description": "Optional Sonarr API key.",
          "format": "string",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "YARR_RADARR_URL",
          "description": "Optional Radarr base URL.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "http://radarr:7878"
        },
        {
          "name": "YARR_RADARR_API_KEY",
          "description": "Optional Radarr API key.",
          "format": "string",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "YARR_PLEX_URL",
          "description": "Optional Plex base URL.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "http://plex:32400"
        },
        {
          "name": "YARR_PLEX_TOKEN",
          "description": "Optional Plex token.",
          "format": "string",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "YARR_VERSION",
          "description": "Optional GitHub release tag override for the downloaded Yarr binary.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "v2.0.0"
        },
        {
          "name": "YARR_REPO",
          "description": "Optional GitHub owner/repo override for release asset downloads.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "jmagar/yarr",
          "placeholder": "jmagar/yarr"
        },
        {
          "name": "YARR_RELEASE_BASE_URL",
          "description": "Optional release download base URL override.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "RUST_LOG",
          "description": "Tracing filter for Yarr logs.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "info",
          "placeholder": "info"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "namespace": "ai.dinglebear",
      "dnsDomain": "dinglebear.ai",
      "distribution": {
        "npm": "yarr-mcp@2.0.0",
        "nodePackage": "yarr-mcp"
      },
      "buildInfo": {
        "version": "2.0.0",
        "repository": "https://github.com/jmagar/yarr"
      }
    }
  }
}
