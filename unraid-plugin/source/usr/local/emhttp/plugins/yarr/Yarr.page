<?php
/*
 * Thin settings shell. GraphQL requests use the authenticated webGUI session
 * and its CSRF token; configuration and credentials remain server-side.
 */
$yarr_csrf = $var['csrf_token'] ?? '';
if ($yarr_csrf === '') {
    $yarr_csrf = @parse_ini_file('/usr/local/emhttp/state/var.ini')['csrf_token'] ?? '';
}
$yarr_web = '/usr/local/emhttp/plugins/yarr/web';
$yarr_content_token = static function ($path) {
    $digest = @hash_file('sha256', $path);
    return is_string($digest) && preg_match('/\A[0-9a-f]{64}\z/D', $digest) === 1
        ? substr($digest, 0, 12)
        : 'missing';
};
$yarr_settings_css_v = $yarr_content_token("$yarr_web/yarr-settings.css");
$yarr_settings_js_v = $yarr_content_token("$yarr_web/yarr-settings.js");
?>
<script>window.csrf_token = <?= json_encode((string) $yarr_csrf, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;</script>
<link rel="stylesheet" href="/plugins/yarr/web/yarr-settings.css?v=<?= $yarr_settings_css_v ?>">
<noscript><p>This settings page requires JavaScript.</p></noscript>
<yarr-settings-app></yarr-settings-app>
<script type="module" src="/plugins/yarr/web/yarr-settings.js?v=<?= $yarr_settings_js_v ?>"></script>
