<?php
/*
 * Main/Dashboard mount for the compact Yarr runtime bundle. It deliberately
 * does not load the full settings application.
 */
$yarr_dashboard_web = '/usr/local/emhttp/plugins/yarr/web';
$yarr_content_token = static function ($path) {
    $digest = @hash_file('sha256', $path);
    return is_string($digest) && preg_match('/\A[0-9a-f]{64}\z/D', $digest) === 1
        ? substr($digest, 0, 12)
        : 'missing';
};
$yarr_dashboard_css_v = $yarr_content_token("$yarr_dashboard_web/yarr-dashboard.css");
$yarr_dashboard_js_v = $yarr_content_token("$yarr_dashboard_web/yarr-dashboard.js");
?>
<link rel="stylesheet" href="/plugins/yarr/web/yarr-dashboard.css?v=<?= $yarr_dashboard_css_v ?>">
<noscript><p>The Yarr dashboard widget requires JavaScript.</p></noscript>
<yarr-dashboard></yarr-dashboard>
<script type="module" src="/plugins/yarr/web/yarr-dashboard.js?v=<?= $yarr_dashboard_js_v ?>"></script>
