#!/bin/bash
set -u

YARR_RC=${YARR_RC:-/etc/rc.d/rc.yarr}
YARR_EVENT_ATTEMPTS=${YARR_EVENT_ATTEMPTS:-3}
YARR_EVENT_LOCK_WAIT_SECONDS=${YARR_EVENT_LOCK_WAIT_SECONDS:-10}
YARR_EVENT_RETRY_SECONDS=${YARR_EVENT_RETRY_SECONDS:-2}

report_failure() {
    local message=$1
    printf 'yarr array-start hook: %s\n' "$message" >&2
    logger -t yarr-plugin -- "array-start hook: $message" 2>/dev/null || true
}

attempt=1
while (( attempt <= YARR_EVENT_ATTEMPTS )); do
    if YARR_LOCK_WAIT_SECONDS=$YARR_EVENT_LOCK_WAIT_SECONDS "$YARR_RC" start; then
        exit 0
    fi
    if (( attempt < YARR_EVENT_ATTEMPTS )); then
        sleep "$YARR_EVENT_RETRY_SECONDS"
    fi
    ((attempt += 1))
done

report_failure "failed after ${YARR_EVENT_ATTEMPTS} bounded attempts"
exit 1
